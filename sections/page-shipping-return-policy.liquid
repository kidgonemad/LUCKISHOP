{% layout 'theme' %}

<div class="page-width page-content">
  <div class="shipping-return-policy">
    <h1>{{ page.title }}</h1>
    <div class="rte">
      <div class="policy-content">
        <p>All sales are final. If you receive a defective or incorrect item, we'll replace it at no extra cost.</p>
        
        <p>Customers are responsible for reshipping fees if a package is returned due to an incorrect address—please double-check your info before ordering!</p>
        
        <p>Most products take 2–3 weeks to ship. Estimated times are listed in each product description. For any other concerns please contact us via email below.</p>
        
        <div class="email-container">
          <a href="mailto:luckivaultinfo@gmail.com" class="email-link">
            <img src="{{ 'mail.svg' | asset_url }}" alt="Email Support" class="email-icon">
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
.shipping-return-policy {
  max-width: 800px;
  margin: 0 auto;
  padding: 40px 20px;
}

.shipping-return-policy h1 {
  text-align: center;
  margin-bottom: 30px;
  font-size: 32px;
}

.rte {
  font-size: 16px;
  line-height: 1.6;
}

.policy-content {
  margin-bottom: 40px;
}

.policy-content p {
  margin-bottom: 20px;
  color: #333;
}

.email-container {
  text-align: center;
  margin-top: 30px;
}

.email-link {
  display: inline-block;
}

.email-icon {
  width: 32px;
  height: 32px;
  transition: transform 0.4s ease;
}

.email-icon:hover {
  transform: scale(1.2);
}

@media screen and (max-width: 768px) {
  .shipping-return-policy {
    padding: 20px;
  }
  
  .shipping-return-policy h1 {
    font-size: 28px;
  }
  
  .policy-content {
    font-size: 16px;
  }

  .email-icon {
    width: 28px;
    height: 28px;
  }
}
</style> 
<style>
.bg-video-container {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -2;
  overflow: hidden;
}

.bg-video {
  width: 100%;
  height: 100%;
  object-fit: cover;
  filter: brightness(0.7);
}

.tour-page-wrapper {
  position: relative;
  width: 100%;
  min-height: 100vh;
  padding: 180px 20px 40px;
  box-sizing: border-box;
  z-index: 1;
  color: white;
}

.tour-content {
  max-width: 1200px;
  margin: 0 auto;
  padding: 40px;
  position: relative;
  z-index: 2;
}

.tour-header {
  text-align: center;
  margin-bottom: 60px;
  padding-bottom: 30px;
}

.tour-header h1 {
  font-size: 9em;
  color: black;
  margin-bottom: 20px;
  letter-spacing: 2px;
  text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.5);
  font-family: 'gog-regular', monospace;
}
main {
  margin-top: -200px !important;
}

@media (max-width: 768px) {
  main {
    margin-top: -200px !important;
  }
}
.tour-list {
  display: flex;
  flex-direction: column;
  gap: 20px;
  backdrop-filter: none;
  padding: 20px;
  border-radius: 15px;
  position: relative;
  z-index: 2;
  background: transparent;
}

.tour-item {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr 1fr;
  padding: 25px;
  border-bottom: 3px solid rgba(255, 255, 255, 0.3);
  transition: all 0.3s ease;
  font-size: 1.2em;
  align-items: center;
  background: transparent;
  filter: blur(1px);
}

.tour-item:hover {
  background: transparent;
  transform: translateX(10px);
  border-radius: 8px;
}

.date {
  font-weight: bold;
  color: black;
  font-size: 1.1em;
  filter: blur(6px);
}

.venue {
  font-style: italic;
  color: black;
  filter: blur(6px);
}

.city {
  color: black;
  filter: blur(6px);
}

.status {
  text-align: right;
  font-weight: bold;
  letter-spacing: 1px;
  color: black;
  filter: blur(6px);
}

.tour-item:hover .date,
.tour-item:hover .venue,
.tour-item:hover .city,
.tour-item:hover .status {
  filter: blur(6px);
}

.status.crossed {
  text-decoration: line-through;
  color: #ff4444;
  opacity: 0.7;
}

.tour-item.sold-out {
  opacity: 0.7;
}

.tour-item.cancelled {
  opacity: 0.7;
}

@media (max-width: 768px) {
  .tour-header h1 {
    font-size: 3.5em;
  }

  .tour-item {
    grid-template-columns: 1fr;
    gap: 10px;
    text-align: center;
    padding: 20px 15px;
  }
  
  .status {
    text-align: center;
  }
  
  .tour-content {
    padding: 20px;
  }

  .tour-item:hover {
    transform: scale(1.02);
  }
}
</style>

<!-- TUNE TOOL — add ?tune=1 to URL to enable -->
<script>
(function() {
  if (window.location.search.indexOf('tune=1') === -1) return;

  var isMobile = window.innerWidth <= 768;
  var panel = document.createElement('div');
  panel.id = 'tune-panel';
  panel.style.cssText = 'position:fixed;top:30px;right:10px;background:rgba(0,0,0,0.92);color:#fff;padding:14px;z-index:99999;font-family:monospace;font-size:11px;border-radius:8px;width:300px;max-height:90vh;overflow-y:auto;';

  var controls = [
    {label: 'Wrapper Padding Top', target: '.tour-page-wrapper', prop: 'paddingTop', unit: 'px', min: 0, max: 400, step: 0.01},
    {label: 'Wrapper Padding Bottom', target: '.tour-page-wrapper', prop: 'paddingBottom', unit: 'px', min: 0, max: 200, step: 0.01},
    {label: 'Content Padding', target: '.tour-content', prop: 'padding', unit: 'px', min: 0, max: 100, step: 0.01},
    {label: 'Title Font Size', target: '.tour-header h1', prop: 'fontSize', unit: 'em', min: 1, max: 15, step: 0.01},
    {label: 'Title Margin Bottom', target: '.tour-header h1', prop: 'marginBottom', unit: 'px', min: 0, max: 100, step: 0.01},
    {label: 'Header Margin Bottom', target: '.tour-header', prop: 'marginBottom', unit: 'px', min: 0, max: 150, step: 0.01},
    {label: 'Header Padding Bottom', target: '.tour-header', prop: 'paddingBottom', unit: 'px', min: 0, max: 100, step: 0.01},
    {label: 'List Gap', target: '.tour-list', prop: 'gap', unit: 'px', min: 0, max: 60, step: 0.01},
    {label: 'Item Padding', target: '.tour-item', prop: 'padding', unit: 'px', min: 0, max: 60, step: 0.01},
    {label: 'Item Font Size', target: '.tour-item', prop: 'fontSize', unit: 'em', min: 0.5, max: 3, step: 0.01},
  ];

  function getVal(c) {
    var el = document.querySelector(c.target);
    if (!el) return c.min;
    var raw = getComputedStyle(el)[c.prop];
    return parseFloat(raw) || c.min;
  }

  var html = '<div style="font-weight:bold;margin-bottom:8px;font-size:13px;">TOUR TUNER ' + (isMobile ? '(MOBILE)' : '(DESKTOP)') + '</div>';

  controls.forEach(function(c, i) {
    var val = getVal(c);
    html += '<div style="margin:6px 0;">' +
      '<div style="display:flex;justify-content:space-between;"><span>' + c.label + '</span><span id="tv' + i + '">' + val + '</span></div>' +
      '<input type="range" id="tr' + i + '" min="' + c.min + '" max="' + c.max + '" step="' + c.step + '" value="' + val + '" style="width:100%;accent-color:#e54d29;">' +
      '</div>';
  });

  html += '<button id="tune-copy" style="margin-top:12px;padding:8px 16px;background:#e54d29;color:#fff;border:none;cursor:pointer;font-size:12px;width:100%;">COPY CSS VALUES</button>';
  panel.innerHTML = html;
  document.body.appendChild(panel);

  controls.forEach(function(c, i) {
    var slider = document.getElementById('tr' + i);
    var display = document.getElementById('tv' + i);

    slider.addEventListener('input', function() {
      var v = parseFloat(this.value);
      display.textContent = v;
      var els = document.querySelectorAll(c.target);
      els.forEach(function(el) {
        el.style[c.prop] = v + c.unit;
      });
    });
  });

  document.getElementById('tune-copy').addEventListener('click', function() {
    var lines = [isMobile ? '/* Mobile */' : '/* Desktop */'];
    controls.forEach(function(c, i) {
      var v = document.getElementById('tr' + i).value;
      lines.push(c.label + ': ' + v + c.unit);
    });
    navigator.clipboard.writeText(lines.join('\n')).then(function() {
      document.getElementById('tune-copy').textContent = 'COPIED!';
      setTimeout(function() { document.getElementById('tune-copy').textContent = 'COPY CSS VALUES'; }, 1500);
    });
  });
})();
</script>
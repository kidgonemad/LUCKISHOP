<!-- TUNE TOOL — add ?tune=1 to URL to enable -->
<script>
(function() {
  if (window.location.search.indexOf('tune=1') === -1) return;

  var isMobile = window.innerWidth <= 768;
  var panel = document.createElement('div');
  panel.id = 'tune-panel';
  panel.style.cssText = 'position:fixed;top:30px;right:10px;background:rgba(0,0,0,0.92);color:#fff;padding:14px;z-index:99999;font-family:monospace;font-size:11px;border-radius:8px;width:300px;max-height:90vh;overflow-y:auto;cursor:move;';

  // Make panel draggable
  var panelDrag = false, panelOffX, panelOffY;
  panel.addEventListener('mousedown', function(e) {
    if (e.target.tagName === 'INPUT' || e.target.tagName === 'BUTTON') return;
    panelDrag = true;
    panelOffX = e.clientX - panel.getBoundingClientRect().left;
    panelOffY = e.clientY - panel.getBoundingClientRect().top;
    panel.style.transition = 'none';
  });
  document.addEventListener('mousemove', function(e) {
    if (!panelDrag) return;
    panel.style.left = (e.clientX - panelOffX) + 'px';
    panel.style.top = (e.clientY - panelOffY) + 'px';
    panel.style.right = 'auto';
  });
  document.addEventListener('mouseup', function() { panelDrag = false; });
  panel.addEventListener('touchstart', function(e) {
    if (e.target.tagName === 'INPUT' || e.target.tagName === 'BUTTON') return;
    panelDrag = true;
    var t = e.touches[0];
    panelOffX = t.clientX - panel.getBoundingClientRect().left;
    panelOffY = t.clientY - panel.getBoundingClientRect().top;
    panel.style.transition = 'none';
  }, {passive: true});
  document.addEventListener('touchmove', function(e) {
    if (!panelDrag) return;
    var t = e.touches[0];
    panel.style.left = (t.clientX - panelOffX) + 'px';
    panel.style.top = (t.clientY - panelOffY) + 'px';
    panel.style.right = 'auto';
  }, {passive: true});
  document.addEventListener('touchend', function() { panelDrag = false; });

  var controls = [
    {label: 'Video Width', target: '.carousel-item', prop: 'width', unit: 'px', min: 100, max: 800, step: 0.01},
    {label: 'Video Height', target: '.carousel-item', prop: 'height', unit: 'px', min: 60, max: 500, step: 0.01},
    {label: 'Orbit Radius', id: 'radius', min: 100, max: 1500, step: 0.01, isJS: true},
    {label: 'Vertical Offset', id: 'verticalOffset', min: 0, max: 400, step: 0.01, isJS: true},
    {label: 'Page Height', target: '.page-music', prop: 'height', unit: 'vh', min: 30, max: 200, step: 0.01},
    {label: 'Page Padding Top', target: '.page-music', prop: 'paddingTop', unit: 'px', min: 0, max: 300, step: 0.01},
    {label: 'Page Padding Bottom', target: '.page-music', prop: 'paddingBottom', unit: 'px', min: 0, max: 300, step: 0.01},
    {label: 'Frame Size %', target: '.video-frame', prop: 'width', unit: '%', min: 100, max: 150, step: 0.01, also: 'height'},
    {label: 'Video Scale (active)', id: 'activeScale', min: 0.3, max: 2, step: 0.01, isJS: true},
    {label: 'Gap Between Videos', id: 'gapMultiplier', min: 0.1, max: 3, step: 0.01, isJS: true},
    {label: 'Container Width %', target: '.video-container', prop: 'width', unit: '%', min: 50, max: 100, step: 0.01, alsoTarget: '.video-overlay'},
    {label: 'Container Height %', target: '.video-container', prop: 'height', unit: '%', min: 50, max: 100, step: 0.01, alsoTarget: '.video-overlay'},
    {label: 'Container Top %', target: '.video-container', prop: 'top', unit: '%', min: 40, max: 60, step: 0.01, alsoTarget: '.video-overlay'},
    {label: 'Iframe Scale X', target: '.video-container iframe', prop: '_scaleX', unit: '', min: 0.5, max: 1.2, step: 0.01, isTransform: true},
    {label: 'Iframe Scale Y', target: '.video-container iframe', prop: '_scaleY', unit: '', min: 0.5, max: 1.2, step: 0.01, isTransform: true},
    {label: 'Title Bottom Offset', target: '.video-title', prop: 'bottom', unit: 'px', min: -200, max: 100, step: 0.01},
    {label: 'Title Font Size', target: '.video-title', prop: 'fontSize', unit: 'em', min: 0.3, max: 4, step: 0.01},
  ];

  var iframeScaleX = 1;
  var iframeScaleY = 0.94;

  var activeScale = 1;
  var gapMultiplier = 1;

  var html = '<div style="font-weight:bold;margin-bottom:8px;font-size:13px;">CAROUSEL TUNER ' + (isMobile ? '(MOBILE)' : '(DESKTOP)') + '</div>';

  function getVal(c) {
    if (c.isJS) {
      if (c.id === 'radius') return radius;
      if (c.id === 'verticalOffset') return verticalOffset;
      if (c.id === 'activeScale') return activeScale;
      if (c.id === 'gapMultiplier') return gapMultiplier;
    }
    var el = document.querySelector(c.target);
    if (!el) return c.min;
    var raw = getComputedStyle(el)[c.prop];
    return parseFloat(raw) || c.min;
  }

  controls.forEach(function(c, i) {
    var val = getVal(c);
    html += '<div style="margin:6px 0;">' +
      '<div style="display:flex;justify-content:space-between;"><span>' + c.label + '</span><span id="tv' + i + '">' + val + '</span></div>' +
      '<input type="range" id="tr' + i + '" min="' + c.min + '" max="' + c.max + '" step="' + c.step + '" value="' + val + '" style="width:100%;accent-color:#e54d29;">' +
      '</div>';
  });

  html += '<button id="tune-fit" style="margin-top:12px;padding:8px 16px;background:#333;color:#fff;border:none;cursor:pointer;font-size:12px;width:100%;">FIT VIDEO TO FRAME</button>';
  html += '<button id="tune-copy" style="margin-top:6px;padding:8px 16px;background:#e54d29;color:#fff;border:none;cursor:pointer;font-size:12px;width:100%;">COPY CSS VALUES</button>';
  panel.innerHTML = html;
  document.body.appendChild(panel);

  controls.forEach(function(c, i) {
    var slider = document.getElementById('tr' + i);
    var display = document.getElementById('tv' + i);

    slider.addEventListener('input', function() {
      var v = parseFloat(this.value);
      display.textContent = v;

      if (c.isJS) {
        if (c.id === 'radius') { radius = v; setupCarousel(); }
        if (c.id === 'verticalOffset') { verticalOffset = v; setupCarousel(); }
        if (c.id === 'activeScale') { activeScale = v; setupCarousel(); }
        if (c.id === 'gapMultiplier') { gapMultiplier = v; setupCarousel(); }
        return;
      }

      if (c.isTransform) {
        if (c.prop === '_scaleX') iframeScaleX = v;
        if (c.prop === '_scaleY') iframeScaleY = v;
        document.querySelectorAll('.video-container iframe').forEach(function(el) {
          el.style.transform = 'scale(' + iframeScaleX + ', ' + iframeScaleY + ')';
        });
        return;
      }

      var els = document.querySelectorAll(c.target);
      els.forEach(function(el) {
        el.style[c.prop] = v + c.unit;
        /* BUG1 CONFIRMED: c.also never handled - frame height not set during tuning */
      });

      if (c.alsoTarget) {
        document.querySelectorAll(c.alsoTarget).forEach(function(el) {
          el.style[c.prop] = v + c.unit;
        });
      }

      // Update margins for carousel-item width/height changes
      if (c.target === '.carousel-item') {
        els.forEach(function(el) {
          var w = parseFloat(el.style.width);
          var h = parseFloat(el.style.height);
          if (c.prop === 'width') el.style.marginLeft = -(w/2) + 'px';
          if (c.prop === 'height') el.style.marginTop = -(h/2) + 'px';
        });
      }
    });
  });

  // Patch setupCarousel to use activeScale and gapMultiplier
  var origCalc = calculatePosition;
  calculatePosition = function(index, rotation) {
    var pos = origCalc(index, rotation);
    if (index === currentPlayer) {
      pos.scale = activeScale;
    } else {
      pos.scale *= gapMultiplier;
    }
    pos.x *= gapMultiplier;
    if (!isMobile) pos.y *= gapMultiplier;
    else pos.y *= gapMultiplier;
    return pos;
  };

  var fitted = false;
  document.getElementById('tune-fit').addEventListener('click', function() {
    fitted = !fitted;
    var containers = document.querySelectorAll('.video-container');
    var overlays = document.querySelectorAll('.video-overlay');
    var iframes = document.querySelectorAll('.video-container iframe');
    /* Frame inner cutout: x=175-5073 (93.3%), y=295-3039 (85.4%), center at 50% x 51.9% */
    if (fitted) {
      containers.forEach(function(el) { el.style.width = '93.3%'; el.style.height = '85.4%'; el.style.top = '51.9%'; });
      overlays.forEach(function(el) { el.style.width = '93.3%'; el.style.height = '85.4%'; el.style.top = '51.9%'; });
      iframes.forEach(function(el) { el.style.transform = 'scale(1)'; });
      this.style.background = '#e54d29';
      this.textContent = 'FITTED — CLICK TO RESET';
    } else {
      containers.forEach(function(el) { el.style.width = '93%'; el.style.height = '76%'; el.style.top = '50%'; });
      overlays.forEach(function(el) { el.style.width = '93%'; el.style.height = '76%'; el.style.top = '50%'; });
      iframes.forEach(function(el) { el.style.transform = 'scale(1, 0.94)'; });
      this.style.background = '#333';
      this.textContent = 'FIT VIDEO TO FRAME';
    }
  });

  document.getElementById('tune-copy').addEventListener('click', function() {
    var lines = [isMobile ? '/* Mobile */' : '/* Desktop */'];
    controls.forEach(function(c, i) {
      var v = document.getElementById('tr' + i).value;
      lines.push(c.label + ': ' + v + (c.unit || ''));
    });
    navigator.clipboard.writeText(lines.join('\n')).then(function() {
      document.getElementById('tune-copy').textContent = 'COPIED!';
      setTimeout(function() { document.getElementById('tune-copy').textContent = 'COPY CSS VALUES'; }, 1500);
    });
  });
})();
</script>


<div class="page-music">
  <div class="carousel-container">
    <div class="carousel">
      {% assign titles = "LUCKI - OVERTH!NKING,LUCKI - X6,LUCKI - Not So Virgo of You,LUCKI - HEAVY ON MY HEART,LUCKI & Lil Yachty - I Don't Care...,LUCKI - Free Mr.Banks" | split: ',' %}
      {% assign frames = "mp4-01.svg,mp4-02.svg,mp4-03.svg,mp4-04.svg,mp4-05.svg,mp4-06.svg" | split: ',' %}
      
      {% for i in (1..6) %}
        <div class="carousel-item {% if forloop.first %}active{% endif %}" data-index="{{ forloop.index0 }}" onclick="selectVideo({{ forloop.index0 }})">
          <div class="frame-container">
            <img src="{{ 'video-frames/' | append: frames[forloop.index0] | asset_url }}" class="video-frame" alt="Video frame {{ forloop.index }}">
            <div class="video-container" id="player{{ forloop.index }}"></div>
            <div class="video-overlay"></div>
          </div>
          <h3 class="video-title">{{ titles[forloop.index0] }}</h3>
        </div>
      {% endfor %}
    </div>
    <button class="stop-rotation" onclick="toggleRotation()">
      <span class="stop-icon"></span>
      <span class="play-icon"></span>
    </button>
  </div>
</div>

<script src="https://www.youtube.com/iframe_api"></script>
<script>
  var players = [];
  var currentPlayer = 0;
  var videoIds = [
    'Ed3_NqN7pls',
    'KKAYk5TG09s',
    'RhPABrBoek8',
    'IgBLFQBCCuU',
    'x9pVY4rBv8Q',
    'yoKU-adT3kg'
  ];
  
  var carousel = document.querySelector('.carousel');
  var items = document.querySelectorAll('.carousel-item');
  var radius = window.innerWidth <= 768 ? 380 : 650;
  var verticalOffset = window.innerWidth <= 768 ? 75 : 130;
  var activeScale = 1.28;
  var gapMultiplier = 0.7;
  var theta = (2 * Math.PI) / items.length;
  var currentRotation = 0;
  var autoRotationEnabled = true;
  var rotationTimeout;
  var isMouseOver = false;
  var isMobile = window.innerWidth <= 768;

  window.addEventListener('resize', () => {
    isMobile = window.innerWidth <= 768;
    radius = isMobile ? 380 : 650;
    verticalOffset = isMobile ? 75 : 130;
    activeScale = 1.28;
    gapMultiplier = 0.7;
    setupCarousel();
  });

  function calculatePosition(index, rotation) {
    const angle = theta * index + rotation;

    if (isMobile) {
      // Mobile: same logic as desktop but vertical (y = spread axis, x = 0)
      const y = Math.sin(angle) * radius;
      const z = Math.cos(angle) * radius;

      const baseOffset = -Math.abs(Math.cos(angle)) * verticalOffset;
      const activeOffset = index === currentPlayer ? 100 : 0;
      const xOffset = baseOffset + activeOffset;

      var scale = 0.6 + (0.4 * (1 + Math.cos(angle))) / 2;
      if (index === currentPlayer) {
        scale = activeScale;
      } else {
        scale *= gapMultiplier;
      }

      return {
        x: 0,
        y: y * gapMultiplier,
        z: z,
        scale: scale,
        opacity: 0.3 + (0.7 * scale),
        zIndex: Math.round(z),
        pointerEvents: 'auto'
      };
    } else {
      // Desktop: horizontal wheel
      const x = Math.sin(angle) * radius;
      const z = Math.cos(angle) * radius;

      const baseOffset = -Math.abs(Math.cos(angle)) * verticalOffset;
      const activeOffset = index === currentPlayer ? 100 : 0;
      const yOffset = baseOffset + activeOffset;

      var scale = 0.6 + (0.4 * (1 + Math.cos(angle))) / 2;
      if (index === currentPlayer) {
        scale = activeScale;
      } else {
        scale *= gapMultiplier;
      }

      return {
        x: x * gapMultiplier,
        y: yOffset * gapMultiplier,
        z: z,
        scale: scale,
        opacity: 0.3 + (0.7 * scale),
        zIndex: Math.round(z),
        pointerEvents: 'auto'
      };
    }
  }

  function setupCarousel() {
    requestAnimationFrame(() => {
      items.forEach((item, i) => {
        const pos = calculatePosition(i, currentRotation);
        item.style.transform = `translate3d(${pos.x}px, ${pos.y}px, ${pos.z}px) scale(${pos.scale})`;
        item.style.opacity = pos.opacity;
        item.style.zIndex = pos.zIndex;
        item.style.pointerEvents = pos.pointerEvents;
      });
    });
  }

  function rotateCarousel(newIndex, immediate = false) {
    const targetRotation = -theta * newIndex;
    currentPlayer = newIndex;
    
    // Determine shortest rotation path
    let deltaRotation = targetRotation - currentRotation;
    if (Math.abs(deltaRotation) > Math.PI) {
      deltaRotation = deltaRotation > 0 ? deltaRotation - 2 * Math.PI : deltaRotation + 2 * Math.PI;
    }
    
    currentRotation += deltaRotation;
    
    items.forEach((item, i) => {
      const pos = calculatePosition(i, currentRotation);
      item.style.transition = immediate ? 'none' : 'all 1.5s cubic-bezier(0.4, 0, 0.2, 1)';
      item.style.transform = `translate3d(${pos.x}px, ${pos.y}px, ${pos.z}px) scale(${pos.scale})`;
      item.style.opacity = pos.opacity;
      item.style.zIndex = pos.zIndex;
      item.style.pointerEvents = pos.pointerEvents;
      
      // Update active state based on z-position
      item.classList.toggle('active', i === currentPlayer);
    });
  }

  function onYouTubeIframeAPIReady() {
    let loadedPlayers = 0;
    
    videoIds.forEach((videoId, index) => {
      players[index] = new YT.Player('player' + (index + 1), {
        height: '360',
        width: '640',
        videoId: videoId,
        playerVars: {
          'autoplay': 0,
          'controls': 1,
          'showinfo': 0,
          'rel': 0,
          'iv_load_policy': 3,
          'modestbranding': 1
        },
        events: {
          'onReady': (event) => {
            loadedPlayers++;
            if (loadedPlayers === videoIds.length) {
              // Start with first video
              rotateCarousel(0, true);
              if (autoRotationEnabled) {
                setTimeout(() => {
                  playCurrentVideo();
                }, 1000);
              }
            }
          },
          'onStateChange': onPlayerStateChange
        }
      });
    });
  }

  function selectVideo(index) {
    if (index === currentPlayer) return;
    
    // Stop all videos first
    players.forEach(player => {
      if (player && typeof player.pauseVideo === 'function') {
        player.pauseVideo();
      }
    });
    
    rotateCarousel(index);
    currentPlayer = index;
    
    // Play the selected video after rotation
    setTimeout(() => {
      if (players[currentPlayer] && typeof players[currentPlayer].playVideo === 'function') {
        players[currentPlayer].playVideo();
      }
    }, 1000);
  }

  function toggleRotation() {
    autoRotationEnabled = !autoRotationEnabled;
    document.querySelector('.stop-rotation').classList.toggle('playing', autoRotationEnabled);
    
    // Stop all videos and rotation when pausing
    if (!autoRotationEnabled) {
      clearTimeout(rotationTimeout);
      players.forEach(player => player.pauseVideo());
    } else {
      // Resume playing current video and rotation
      if (!isMouseOver) {
        players[currentPlayer].playVideo();
        rotationTimeout = setTimeout(playNextVideo, 15000);
      }
    }
  }

  function playCurrentVideo() {
    // Ensure all other videos are stopped
    players.forEach((player, index) => {
      if (index !== currentPlayer) {
        player.stopVideo();
      }
    });
    
    // Only play if rotation is enabled
    if (autoRotationEnabled) {
      players[currentPlayer].playVideo();
      
      if (!isMouseOver) {
        rotationTimeout = setTimeout(playNextVideo, 15000);
      }
    }
  }

  function playNextVideo() {
    const nextIndex = (currentPlayer + 1) % players.length;
    selectVideo(nextIndex); // This will handle rotation and playback
  }

  function onPlayerStateChange(event) {
    const videoIndex = players.findIndex(player => player === event.target);
    
    if (event.data === YT.PlayerState.ENDED) {
      if (autoRotationEnabled && !isMouseOver) {
        playNextVideo();
      } else if (videoIndex === currentPlayer) {
        event.target.playVideo(); // Loop current video if rotation is disabled
      }
    } else if (event.data === YT.PlayerState.PLAYING) {
      // If a video starts playing that isn't the current one, stop it
      if (videoIndex !== currentPlayer) {
        event.target.pauseVideo();
      } else {
        // Make sure all other videos are stopped
        players.forEach((player, idx) => {
          if (idx !== currentPlayer) {
            player.pauseVideo();
          }
        });
      }
    }
  }

  // Update mouse interaction handlers
  document.querySelector('.carousel').addEventListener('mouseenter', () => {
    isMouseOver = true;
    clearTimeout(rotationTimeout);
  });

  document.querySelector('.carousel').addEventListener('mouseleave', () => {
    isMouseOver = false;
    if (autoRotationEnabled) {
      rotationTimeout = setTimeout(playNextVideo, 15000);
    }
  });

  // Add initial class to stop-rotation button
  document.querySelector('.stop-rotation').classList.add('playing');

  // Add auto-rotation functionality
  let lastMouseMoveTime = Date.now();
  let autoRotationInterval;

  function startAutoRotation() {
    clearInterval(autoRotationInterval);
    autoRotationInterval = setInterval(() => {
      if (Date.now() - lastMouseMoveTime > 15000 && autoRotationEnabled) {
        const nextIndex = (currentPlayer + 1) % players.length;
        selectVideo(nextIndex);
      }
    }, 15000);
  }

  // Update mouse movement detection
  document.addEventListener('mousemove', () => {
    lastMouseMoveTime = Date.now();
  });

  // Start auto-rotation when page loads
  document.addEventListener('DOMContentLoaded', () => {
    setupCarousel();
    startAutoRotation();
  });

  var editMode = false;
  var selectedContainer = null;
  var editDragging = false;
  var editOffsetX, editOffsetY;

  function toggleEditMode() {
    editMode = !editMode;
    var btn = document.getElementById('edit-pos-btn');
    var containers = document.querySelectorAll('.video-container');
    var overlays = document.querySelectorAll('.video-overlay');

    if (editMode) {
      // Stop all videos and rotation
      autoRotationEnabled = false;
      clearTimeout(rotationTimeout);
      players.forEach(function(p) { if (p && p.pauseVideo) p.pauseVideo(); });

      btn.textContent = 'SAVE & EXIT';
      btn.style.background = '#333';

      // Show edit panel
      var panel = document.createElement('div');
      panel.id = 'edit-panel';
      panel.style.cssText = 'position:fixed;top:30px;left:10px;background:rgba(0,0,0,0.92);color:#fff;padding:14px;z-index:99999;font-family:monospace;font-size:11px;border-radius:8px;width:240px;';
      panel.innerHTML = '<div style="font-weight:bold;margin-bottom:8px;">POSITION EDITOR</div>' +
        '<div>Click a video to select it, then drag to reposition inside the frame.</div>' +
        '<div id="edit-coords" style="margin-top:10px;"></div>' +
        '<button id="edit-copy" style="margin-top:10px;padding:8px 12px;background:#e54d29;color:#fff;border:none;cursor:pointer;font-size:12px;width:100%;">COPY ALL POSITIONS</button>';
      document.body.appendChild(panel);

      containers.forEach(function(c, i) {
        c.style.outline = '2px dashed #e54d29';
        c.style.cursor = 'grab';
        c.style.zIndex = '50';
      });

      overlays.forEach(function(o) {
        o.style.display = 'none';
      });

      // Disable carousel clicking
      document.querySelectorAll('.carousel-item').forEach(function(item) {
        item.style.pointerEvents = 'none';
      });
      containers.forEach(function(c) {
        c.style.pointerEvents = 'auto';
      });

      document.getElementById('edit-copy').addEventListener('click', function() {
        var lines = [];
        containers.forEach(function(c, i) {
          lines.push('Video ' + (i+1) + ': top=' + c.style.top + ' left=' + (c.style.left || '50%') + ' width=' + c.style.width + ' height=' + c.style.height);
        });
        navigator.clipboard.writeText(lines.join('\n')).then(function() {
          document.getElementById('edit-copy').textContent = 'COPIED!';
          setTimeout(function() { document.getElementById('edit-copy').textContent = 'COPY ALL POSITIONS'; }, 1500);
        });
      });

      updateEditCoords();

    } else {
      btn.textContent = 'EDIT POSITIONS';
      btn.style.background = '#e54d29';
      autoRotationEnabled = true;

      var panel = document.getElementById('edit-panel');
      if (panel) panel.remove();

      containers.forEach(function(c) {
        c.style.outline = '';
        c.style.cursor = '';
        c.style.zIndex = '1';
      });
      overlays.forEach(function(o) {
        o.style.display = '';
      });
      document.querySelectorAll('.carousel-item').forEach(function(item) {
        item.style.pointerEvents = '';
      });
    }
  }

  function updateEditCoords() {
    var el = document.getElementById('edit-coords');
    if (!el) return;
    var lines = [];
    document.querySelectorAll('.video-container').forEach(function(c, i) {
      var s = (selectedContainer === c) ? '<b style="color:#e54d29;">' : '<span>';
      var e = (selectedContainer === c) ? '</b>' : '</span>';
      lines.push(s + 'Video ' + (i+1) + ': top=' + (c.style.top || '60%') + ' left=' + (c.style.left || '50%') + e);
    });
    el.innerHTML = lines.join('<br>');
  }

  document.addEventListener('mousedown', function(e) {
    if (!editMode) return;
    var c = e.target.closest('.video-container');
    if (!c) return;
    e.preventDefault();
    selectedContainer = c;
    editDragging = true;
    c.style.cursor = 'grabbing';
    var rect = c.parentElement.getBoundingClientRect();
    editOffsetX = e.clientX;
    editOffsetY = e.clientY;
    updateEditCoords();
  });

  document.addEventListener('mousemove', function(e) {
    if (!editDragging || !selectedContainer) return;
    var parent = selectedContainer.parentElement;
    var rect = parent.getBoundingClientRect();
    var dx = e.clientX - editOffsetX;
    var dy = e.clientY - editOffsetY;
    editOffsetX = e.clientX;
    editOffsetY = e.clientY;

    var curTop = parseFloat(selectedContainer.style.top) || 60;
    var curLeft = parseFloat(selectedContainer.style.left) || 50;
    var newTop = curTop + (dy / rect.height * 100);
    var newLeft = curLeft + (dx / rect.width * 100);

    selectedContainer.style.top = newTop.toFixed(2) + '%';
    selectedContainer.style.left = newLeft.toFixed(2) + '%';

    // Sync overlay
    var idx = Array.from(document.querySelectorAll('.video-container')).indexOf(selectedContainer);
    var overlay = document.querySelectorAll('.video-overlay')[idx];
    if (overlay) {
      overlay.style.top = newTop.toFixed(2) + '%';
      overlay.style.left = newLeft.toFixed(2) + '%';
    }
    updateEditCoords();
  });

  document.addEventListener('mouseup', function() {
    if (selectedContainer) selectedContainer.style.cursor = 'grab';
    editDragging = false;
  });

  // Touch support
  document.addEventListener('touchstart', function(e) {
    if (!editMode) return;
    var c = e.target.closest('.video-container');
    if (!c) return;
    e.preventDefault();
    selectedContainer = c;
    editDragging = true;
    var t = e.touches[0];
    editOffsetX = t.clientX;
    editOffsetY = t.clientY;
    updateEditCoords();
  }, {passive: false});

  document.addEventListener('touchmove', function(e) {
    if (!editDragging || !selectedContainer) return;
    e.preventDefault();
    var t = e.touches[0];
    var parent = selectedContainer.parentElement;
    var rect = parent.getBoundingClientRect();
    var dx = t.clientX - editOffsetX;
    var dy = t.clientY - editOffsetY;
    editOffsetX = t.clientX;
    editOffsetY = t.clientY;

    var curTop = parseFloat(selectedContainer.style.top) || 60;
    var curLeft = parseFloat(selectedContainer.style.left) || 50;
    selectedContainer.style.top = (curTop + (dy / rect.height * 100)).toFixed(2) + '%';
    selectedContainer.style.left = (curLeft + (dx / rect.width * 100)).toFixed(2) + '%';

    var idx = Array.from(document.querySelectorAll('.video-container')).indexOf(selectedContainer);
    var overlay = document.querySelectorAll('.video-overlay')[idx];
    if (overlay) {
      overlay.style.top = selectedContainer.style.top;
      overlay.style.left = selectedContainer.style.left;
    }
    updateEditCoords();
  }, {passive: false});

  document.addEventListener('touchend', function() { editDragging = false; });
</script>

<style>
main {
  margin-top: -70px !important;
}

@media (max-width: 768px) {

</div>

<style>
.music-page-wrapper {
  position: relative;
  width: 100%;
  min-height: 100vh;
  padding: 120px 20px 40px;
  box-sizing: border-box;
  z-index: 2;
}

.video-grid {
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 30px;
  padding: 20px;
}

.video-item {
  width: 100%;
  background: rgba(0, 0, 0, 0.3);
  border-radius: 10px;
  overflow: hidden;
  transition: transform 0.3s ease;
  box-shadow: 0 4px 15px rgba(0,0,0,0.2);
}

.video-item:hover {
  transform: scale(1.02);
}

.video-container {
  position: relative;
  width: 100%;
  padding-bottom: 56.25%; /* 16:9 Aspect Ratio */
}

.video-container iframe {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: 8px;
}

@media (max-width: 768px) {
  .music-page-wrapper {
    padding: 100px 10px 20px;
  }
  
  .video-grid {
    grid-template-columns: 1fr;
    gap: 20px;
    padding: 10px;
  }
}
</style> 
<div class="product-page-wrapper">
  <div id="product-container">
    {% assign current_variant = product.selected_or_first_available_variant %}
    {% assign featured_image = current_variant.featured_image | default: product.featured_image %}

    <div id="image-container">
      {% for image in product.images %}
        {% if forloop.first == true %}
          <img class="product-images big" src="{{ image.src | img_url: 'x1600' }}" alt="{{ image.alt | escape }}">
        {% else %}
          <img class="product-images big disabled" src="{{ image.src | img_url: 'x1600' }}" alt="{{ image.alt | escape }}">
        {% endif %}
      {% endfor %}
      <!-- <div id="back-button" class="button"><img src="{{ 'arrow.svg' | asset_url }}"></div>
      <div id="next-button" class="button"><img src="{{ 'arrow.svg' | asset_url }}"></div> -->
    </div>
    <div id="thumbnails">
      {% for image in product.images %}
<!--     	<div class="thumbnail-slide"> -->
          {% if forloop.first == true %}
            <img class="thumbnail curr" src="{{ image.src | img_url: 'x200' }}" alt="{{ image.alt | escape }}">
          {% else %}
            <img class="thumbnail" src="{{ image.src | img_url: 'x200' }}" alt="{{ image.alt | escape }}">
          {% endif %}
<!--     	</div> -->
      {% endfor %}
    </div>

    <div id="product-title">{{ product.title }}</div>
    <div id="product-price">{{ current_variant.price | money }}</div>
    <div id="product-price-comp">{{ current_variant.compare_at_price | money }}</div>

    {% assign product_type = product.title | downcase %}

    <form action="/cart/add" method="post" enctype="multipart/form-data" id="AddToCartForm">
      {% assign is_hoodie = false %}
      {% if product_type contains 'hoodie' %}
        {% assign is_hoodie = true %}
      {% endif %}

      {% assign is_music = false %}
      {% if product_type contains 'vinyl' or product_type contains 'cd' %}
        {% assign is_music = true %}
      {% endif %}

      <select name="id" id="productSelect" {% if is_hoodie %}disabled{% endif %} {% if is_music %}style="display:none;"{% endif %}>
        <option id="select-size" selected='selected' value="">Select Unit</option>
        {% assign soldOut = true %}
        {% for variant in product.variants %}
          {% if variant.available and is_hoodie == false %}
            {% assign soldOut = false %}
            <option value="{{ variant.id }}">
              {{ variant.title }}
            </option>
          {% else %}
            <option disabled="disabled">
              {{ variant.title }} - sold out
            </option>
          {% endif %}
        {% endfor %}
      </select>

      {% if is_music %}
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
      {% endif %}

      {% if is_hoodie %}
        <div class="sold-out-message">This item is currently unavailable</div>
      {% endif %}

      <button type="submit" name="add" id="AddToCart" class="{% if is_hoodie %}disabled{% elsif is_music %}music-btn{% else %}inactive{% endif %}" {% if is_hoodie %}disabled{% endif %}>
        {% if is_hoodie %}Sold Out{% else %}Add to cart{% endif %}
      </button>
    </form>

    <div id="product-details">
      {% if product_type contains 'sweats' %}
        <div class="size-chart-link">
          <a href="#" onclick="openSizeChart('sweats', event)">Size Chart</a>
        </div>
        <ul class="product-features">
          <li>16oz | 100% French Terry Cotton</li>
          <li>Straight leg silhouette</li>
          <li>Hidden zipper pocket in left pocket</li>
          <li>True to size</li>
        </ul>
      {% elsif product_type contains 'hoodie' %}
        <div class="size-chart-link">
          <a href="#" onclick="openSizeChart('hoodie', event)">Size Chart</a>
        </div>
        <ul class="product-features">
          <li>16oz | 100% French Terry cotton</li>
          <li>True to size</li>
          <li>Preshrunk</li>
          <li>Kangaroo pocket | Stitching details on the corner of the pocket</li>
          <li>Cover stitch on sleeve and waist ribbing</li>
          <li>Regular Black</li>
        </ul>
      {% elsif product_type contains 'tee' %}
        <div class="size-chart-link">
          <a href="#" onclick="openSizeChart('tee', event)">Size Chart</a>
        </div>
        <ul class="product-features">
          <li>Unisex</li>
          <li>Made in Los Angeles, Calif.</li>
          <li>6.5 oz/yd2/ 220 g/m2</li>
          <li>18/1 Open-end USA Cotton</li>
          <li>100% Shrink Free Garment dye Cotton</li>
          {% if product.title contains 'DRB CROSSED TEE' or product.title contains 'D.R.B TEE' %}
            <li>Vintage Black</li>
          {% elsif product.title contains 'LFDS TEE' or product.title contains 'BLACK LUCKI TEE' or product.title contains 'TURNED HER INTO A STAR TEE' %}
            <li>Regular Black</li>
          {% endif %}
        </ul>
      {% elsif product_type contains 'long sleeve' %}
        <div class="size-chart-link">
          <a href="#" onclick="openSizeChart('longsleeve', event)">Size Chart</a>
        </div>
        <ul class="product-features">
          <li>Unisex</li>
          <li>Made in Los Angeles, Calif.</li>
          <li>6.5 oz/yd2/ 220 g/m2</li>
          <li>18/1 Open-end USA Cotton</li>
          <li>100% Shrink Free Garment dye Cotton</li>
          <li>EVERY FIELD design on both sleeves</li>
          {% if product.title contains 'EVERY FIELD LONG SLEEVE' %}
            <li>Vintage Black</li>
          {% endif %}
        </ul>
      {% elsif product_type contains 'signed' and product_type contains 'clear' and product_type contains 'vinyl' %}
        <ul class="product-features">
          <li>SIGNED</li>
          <li>Alternative Front and Back Art, 2xLP, Widespine Jacket with Printed Inner Sleeves</li>
          <li>Escape / Clear White Vinyl</li>
        </ul>
      {% elsif product_type contains 'signed' and product_type contains 'brown' and product_type contains 'vinyl' %}
        <ul class="product-features">
          <li>SIGNED</li>
          <li>Alternative Front and Back Art, 2xLP, Widespine Jacket with Printed Inner Sleeves</li>
          <li>Meltdown / Tiger Eye Brown</li>
        </ul>
      {% elsif product_type contains 'signed' and product_type contains 'grey' and product_type contains 'vinyl' %}
        <ul class="product-features">
          <li>SIGNED</li>
          <li>Alternative Front and Back Art, 2xLP, Widespine Jacket with Printed Inner Sleeves</li>
          <li>Overdose / Smoke Grey Swirl Vinyl</li>
        </ul>
      {% elsif product_type contains 'signed' and product_type contains 'vinyl' %}
        <ul class="product-features">
          <li>SIGNED</li>
          <li>2xLP, Widespine Jacket with Printed Inner Sleeves</li>
          <li>Transparent Orange Vinyl</li>
        </ul>
      {% elsif product_type contains 'orange vinyl' %}
        <ul class="product-features">
          <li>UNSIGNED</li>
          <li>2xLP, Widespine Jacket with Printed Inner Sleeves</li>
          <li>Transparent Orange Vinyl</li>
        </ul>
      {% elsif product_type contains 'meltdown' and product_type contains 'vinyl' %}
        <ul class="product-features">
          <li>UNSIGNED</li>
          <li>Alternative Front and Back Art, 2xLP, Widespine Jacket with Printed Inner Sleeves</li>
          <li>Meltdown / Tiger Eye Brown</li>
        </ul>
      {% elsif product_type contains 'overdose' and product_type contains 'vinyl' %}
        <ul class="product-features">
          <li>UNSIGNED</li>
          <li>Alternative Front and Back Art, 2xLP, Widespine Jacket with Printed Inner Sleeves</li>
          <li>Overdose / Smoke Grey Swirl Vinyl</li>
        </ul>
      {% elsif product_type contains 'black vinyl' %}
        <ul class="product-features">
          <li>2xLP, Widespine Jacket with Printed Inner Sleeves</li>
          <li>Solid Black Vinyl</li>
        </ul>
      {% elsif product_type contains 'escape' and product_type contains 'vinyl' %}
        <ul class="product-features">
          <li>UNSIGNED</li>
          <li>Alternative Front and Back Art, 2xLP, Widespine Jacket with Printed Inner Sleeves</li>
          <li>Escape / Clear White Vinyl</li>
        </ul>
      {% elsif product_type contains 'clear' and product_type contains 'vinyl' %}
        <ul class="product-features">
          <li>UNSIGNED</li>
          <li>Alternative Front and Back Art, 2xLP, Widespine Jacket with Printed Inner Sleeves</li>
          <li>Escape / Clear White Vinyl</li>
        </ul>
      {% elsif product_type contains 'cd' %}
        <ul class="product-features">
          <li>Jewel Case CD, Panel Insert</li>
          <li>Standard Disk</li>
        </ul>
      {% endif %}
      <p class="preorder-note"><strong>Note:</strong> This is a PRE-ORDER item. By purchasing, you secure your copy ahead of the official release. Please note that vinyl production is currently underway. Shipping is scheduled to begin on May 12th.</p>
    </div>

    <div id="description">{{ product.description }}</div>
    <div id="support" onclick="openSupportInfo()">Contact Support</div>
    <a id="email-icon" href="mailto:luckivaultinfo@gmail.com">
      <img src="{{ 'mail.svg' | asset_url }}" alt="Email Support">
    </a>
  </div>
</div>


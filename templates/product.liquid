<script>
  document.addEventListener('DOMContentLoaded', function() {
    var soldOut = {% if soldOut %}true{% else %}false{% endif %};
    var isMusic = {% if is_music %}true{% else %}false{% endif %};
    var addToCartButton = document.getElementById('AddToCart');
    var productSelect = document.getElementById('productSelect');

    if(soldOut) {
      addToCartButton.textContent = "Sold out";
      addToCartButton.disabled = true;
    }

    productSelect.addEventListener('change', function() {
      if (this.value) {
        addToCartButton.classList.remove('inactive');
        addToCartButton.disabled = false;
        document.getElementById('select-size').disabled = true;
      }
    });

    document.getElementById('AddToCartForm').addEventListener('submit', function(e) {
      if (!isMusic && !productSelect.value) {
        e.preventDefault();
        alert('Please select a unit');
        return false;
      }
    });

    // Image switching functionality
    var productImages = document.querySelectorAll('.product-images.big');
    var thumbnails = document.querySelectorAll('.thumbnail');
    
    thumbnails.forEach(function(thumbnail, index) {
      thumbnail.addEventListener('click', function() {
        // Hide all product images
        productImages.forEach(function(img) {
          img.classList.add('disabled');
        });
        
        // Remove 'curr' class from all thumbnails
        thumbnails.forEach(function(thumb) {
          thumb.classList.remove('curr');
        });
        
        // Show selected image and highlight thumbnail
        productImages[index].classList.remove('disabled');
        thumbnail.classList.add('curr');
      });
    });
  });

  function openSizeChart(type, event) {
    event.preventDefault();
    const modal = document.getElementById('sizeChartModal');
    
    // Hide all size charts first
    const charts = document.querySelectorAll('.size-chart-section');
    charts.forEach(chart => chart.style.display = 'none');
    
    // Show the selected size chart
    const selectedChart = document.getElementById(type + 'Chart');
    if (selectedChart) {
      selectedChart.style.display = 'block';
    }
    
    modal.style.display = 'flex';
  }

  function closeSizeChart() {
    document.getElementById('sizeChartModal').style.display = 'none';
  }

  // Close modal when clicking outside of it
  window.onclick = function(event) {
    var modal = document.getElementById('sizeChartModal');
    if (event.target == modal) {
      modal.style.display = 'none';
    }
  }

  function openSupportInfo() {
    document.getElementById('supportModal').style.display = 'flex';
    document.getElementById('email-icon').style.display = 'block';
  }

  function closeSupportInfo() {
    document.getElementById('supportModal').style.display = 'none';
  }

  // Close modal when clicking outside of it
  window.onclick = function(event) {
    var modal = document.getElementById('supportModal');
    if (event.target == modal) {
      modal.style.display = 'none';
    }
  }
</script>
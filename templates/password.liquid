{% layout none %}
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="">
    <meta name="author" content="">
    <title>LUCKI STORE CLOSED</title>
    <link rel="stylesheet" href=" {{ 'password.scss.css' | asset_url }} ">
    <style>
      html, body {
        margin: 0;
        padding: 0;
        width: 100%;
        height: 100%;
        overflow: hidden;
        user-select: none;
      }
      .bg-iframe {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        border: none;
        z-index: 0;
      }

      /* ── Lock icon (animated SVG) ── */
      .lock-wrapper {
        position: fixed;
        top: 16px;
        right: 24px;
        z-index: 20;
        cursor: pointer;
        -webkit-tap-highlight-color: transparent;
        padding: 6px;
      }
      svg.lock {
        width: 16px;
        transform-origin: center top;
      }
      .fill-mask, .top-part, .bottom-part { fill: none; }
      .fill-mask-group { clip-path: url(#clip-path); }
      /* Default = CLOSED (locked) — BLACK, shackle down */
      .fill-circle {
        fill: #000;
        transition: fill 0.5s cubic-bezier(0.4, 0, 0.2, 1), r 0.5s cubic-bezier(0.4, 0, 0.2, 1);
      }
      .top-part, .bottom-part {
        stroke: #000;
        stroke-miterlimit: 10;
        transition: stroke 0.5s cubic-bezier(0.4, 0, 0.2, 1);
      }
      .top-part {
        stroke-linecap: round;
        stroke-width: 15.39px;
        transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
      }
      .bottom-part {
        stroke-width: 15px;
      }

      /* When drawer is open — lock fades to WHITE with delay after shake */
      svg.lock.active .fill-circle {
        fill: #e54d29;
        transition: fill 0.6s cubic-bezier(0.4, 0, 0.2, 1) 0.2s;
      }
      svg.lock.active .top-part {
        stroke: #e54d29;
        transition: stroke 0.6s cubic-bezier(0.4, 0, 0.2, 1) 0.15s;
      }
      svg.lock.active .bottom-part {
        stroke: #e54d29;
        transition: stroke 0.6s cubic-bezier(0.4, 0, 0.2, 1) 0.15s;
      }

      /* Lock UNLOCKED (correct password) → shackle goes up */
      svg.lock.unlocked .fill-circle {
        fill: #fff;
        transition: fill 0.4s ease 0.1s, r 0.6s cubic-bezier(0.4, 0, 0.2, 1) 0.3s;
        r: 1.5;
      }
      svg.lock.unlocked .top-part {
        stroke: #fff;
        transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1) 0.2s;
        d: path("M41.5,93.69V56.93A49.24,49.24,0,0,1,90.73,7.69h2.54A49.24,49.24,0,0,1,142.5,56.93v2.26");
      }
      svg.lock.unlocked .bottom-part {
        stroke: #fff;
        transition: stroke 0.4s ease 0.1s;
      }

      /* Shake keyframes — smoother */
      @keyframes LockShake {
        0%   { transform: translateY(0) rotate(0deg); }
        15%  { transform: translateY(-8px) rotate(4deg); }
        30%  { transform: translateY(-12px) rotate(-3deg); }
        50%  { transform: translateY(-6px) rotate(2deg); }
        70%  { transform: translateY(-2px) rotate(-1deg); }
        100% { transform: translateY(0) rotate(0deg); }
      }

      /* ── Password drawer ── */
      .password-drawer {
        position: fixed;
        top: 12px;
        right: 20px;
        z-index: 15;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(0, 0, 0, 0.95);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-radius: 20px;
        padding: 0;
        max-width: 0;
        height: 40px;
        overflow: hidden;
        opacity: 0;
        transition: max-width 0.5s cubic-bezier(0.4, 0, 0.2, 1) 0.4s,
                    opacity 0.4s cubic-bezier(0.4, 0, 0.2, 1) 0.35s,
                    padding 0.5s cubic-bezier(0.4, 0, 0.2, 1) 0.4s;
      }
      .password-drawer.open {
        width: 300px;
        max-width: 300px;
        min-width: 300px;
        opacity: 1;
        padding: 0 40px 0 16px;
      }
      /* When closing — pill retracts first, then lock changes color */
      .password-drawer.closing {
        transition: max-width 0.4s cubic-bezier(0.4, 0, 0.2, 1),
                    opacity 0.3s cubic-bezier(0.4, 0, 0.2, 1),
                    padding 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      }

      #password-content {
        position: relative;
        z-index: 10;
        white-space: nowrap;
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      #password-content h3 {
        display: none;
      }
      #password-content form {
        display: flex;
        align-items: center;
        justify-content: center;
        line-height: 1;
        width: 100%;
        height: 100%;
      }
      .password-dots {
        display: inline-flex;
        align-items: center;
      }

      .password-input {
        border: 0;
        border-bottom: none;
        background-color: transparent;
        color: white;
        height: 28px;
        width: 150px;
        font-size: 14px;
        font-family: Helvetica, sans-serif;
        letter-spacing: 1px;
        caret-color: white;
      }
      .password-input:focus {
        outline: none;
      }
      /* Hidden real input */
      .password-hidden-input {
        position: absolute;
        opacity: 0;
        pointer-events: none;
      }
      /* Dot display */
      .password-dots {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 14px;
        font-family: Helvetica, sans-serif;
        letter-spacing: 3px;
        line-height: 1;
      }
      .password-dots .dot-char {
        display: inline-block;
        transition: none;
        line-height: 1;
      }
      .password-dots .dot-char.revealed {
        font-size: 14px;
      }
      .password-dots .dot-char.hidden {
        font-size: 18px;
        vertical-align: middle;
      }

      .klaviyo-form-container {
        position: fixed;
        left: 50%;
        bottom: 20px;
        transform: translateX(-50%);
        width: 100%;
        max-width: 600px;
        text-align: center;
        z-index: 10;
      }
      @media (max-width: 768px) {
        .klaviyo-form-container {
          padding: 0 20px;
          box-sizing: border-box;
        }
      }
    </style>
  </head>
  <body>
    <!-- Animated lock icon -->
    <div class="lock-wrapper" id="lockWrapper">
      <svg class="lock" id="lockSvg" viewBox="0 0 184 220.19">
        <clipPath id="clip-path">
          <rect class="fill-mask" x="7.5" y="97.69" width="169" height="115" rx="18.5" ry="18.5"/>
        </clipPath>
        <g class="fill-mask-group">
          <circle class="fill-circle" cx="142.5" cy="97.69" r="180"/>
        </g>
        <path class="top-part" d="M41.5,93.69V56.93A49.24,49.24,0,0,1,90.73,7.69h2.54A49.24,49.24,0,0,1,142.5,56.93v33"/>
        <rect class="bottom-part" x="7.5" y="97.69" width="169" height="115" rx="18.5" ry="18.5"/>
      </svg>
    </div>

    <!-- Password drawer that slides out -->
    <div class="password-drawer" id="passwordDrawer">
      <div id="password-content">
        {% form 'storefront_password' %}
          {{ form.errors | default_errors }}
          <input class="password-hidden-input" type="password" name="password" id="password" autocomplete="off" tabindex="-1">
          <span class="password-dots" id="passwordDots"></span>
          <span class="password-cursor" id="passwordCursor" style="display:none;border-right:2px solid rgba(255,255,255,0.7);height:16px;vertical-align:middle;animation:blink 1s step-end infinite;margin-left:1px;"></span>
          <input name="commit" type="submit" value="Enter" style="display:none;">
        {% endform %}
      </div>
    </div>

    <iframe class="bg-iframe" src="https://kidgonemad.github.io/lucki/" allowfullscreen></iframe>


    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
   
    <style>
      @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }
    </style>
    <script>
      (function() {
        var lockWrapper = document.getElementById('lockWrapper');
        var lockSvg = document.getElementById('lockSvg');
        var drawer = document.getElementById('passwordDrawer');
        var passInput = document.getElementById('password');
        var dotsEl = document.getElementById('passwordDots');
        var cursorEl = document.getElementById('passwordCursor');
        var isOpen = false;
        var passwordValue = '';
        var charTimers = [];

        function shake() {
          lockSvg.style.animation = 'none';
          void lockSvg.offsetWidth;
          lockSvg.style.animation = 'LockShake cubic-bezier(0.4, 0, 0.2, 1) 400ms';
        }

        function openDrawer() {
          isOpen = true;
          // 1. Shake
          shake();
          // 2. Color fades via CSS transition delays on .active
          lockSvg.classList.add('active');
          // 3. Pill expands (CSS delay 0.4s waits for shake + color start)
          drawer.classList.remove('closing');
          drawer.classList.add('open');
          cursorEl.style.display = 'inline-block';
          setTimeout(function() { passInput.focus(); }, 900);
        }

        function closeDrawer() {
          isOpen = false;
          // 1. Pill retracts first (no delay via .closing class)
          drawer.classList.add('closing');
          drawer.classList.remove('open');
          cursorEl.style.display = 'none';
          // 2. After pill closes, shake + color reverts
          setTimeout(function() {
            shake();
            lockSvg.classList.remove('active');
          }, 350);
        }

        lockWrapper.addEventListener('click', function(e) {
          e.stopPropagation();
          if (isOpen) {
            closeDrawer();
          } else {
            openDrawer();
          }
        });

        // Also open drawer when tapping the drawer area itself (for re-focus)
        drawer.addEventListener('click', function(e) {
          e.stopPropagation();
          if (isOpen) passInput.focus();
        });

        // Close drawer when clicking outside
        document.addEventListener('click', function(e) {
          if (isOpen && !drawer.contains(e.target) && !lockWrapper.contains(e.target)) {
            closeDrawer();
          }
        });

        // Listen on hidden input for typing
        passInput.addEventListener('input', function() {
          var newVal = passInput.value;

          // Clear old timers for removed chars
          while (charTimers.length > newVal.length) {
            var t = charTimers.pop();
            if (t) clearTimeout(t);
          }

          passwordValue = newVal;
          renderDots();
        });

        // Submit on Enter
        passInput.addEventListener('keydown', function(e) {
          if (e.key === 'Enter') {
            e.preventDefault();
            // Unlock animation then submit
            lockSvg.classList.add('unlocked');
            shake();
            setTimeout(function() {
              passInput.closest('form').submit();
            }, 500);
          }
        });

        function renderDots() {
          var html = '';
          for (var i = 0; i < passwordValue.length; i++) {
            var span = dotsEl.children[i];
            if (span && span.classList.contains('hidden')) {
              // Already a dot, keep it
              html += '<span class="dot-char hidden">&bull;</span>';
            } else if (i === passwordValue.length - 1) {
              // Newest char — show briefly then convert to dot
              html += '<span class="dot-char revealed">' + escapeHtml(passwordValue[i]) + '</span>';
              (function(idx) {
                charTimers[idx] = setTimeout(function() {
                  var el = dotsEl.children[idx];
                  if (el) {
                    el.classList.remove('revealed');
                    el.classList.add('hidden');
                    el.innerHTML = '&bull;';
                  }
                }, 500);
              })(i);
            } else {
              html += '<span class="dot-char hidden">&bull;</span>';
            }
          }
          dotsEl.innerHTML = html;
        }

        function escapeHtml(c) {
          var map = {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":"&#039;"};
          return map[c] || c;
        }

        // Keep hidden input focused when drawer is open
        document.addEventListener('keydown', function(e) {
          if (isOpen && document.activeElement !== passInput) {
            passInput.focus();
          }
        });
      })();
    </script>

    {% if settings.shipping_status_enabled == true %}
      <link rel="stylesheet" href="{{ 'shipping_status.css' | asset_url }}">

      <div id="shipping-status-tab" class="top">
        shipping status
      </div>
      <div id="shipping-status-content">
        <img
          id="shipping-status-exit"
          src="https://cdn.shopify.com/s/files/1/0275/3639/2266/files/times-regular.svg?v=1603996668"
        >
        <div id="shipping-status-text">{{ settings.shipping_status_text }}</div>
      </div>

      <script>
        $("#shipping-status-tab").click(function(){
          $("#shipping-status-content").show();
        });

        $("#shipping-status-exit").click(function(){
          $("#shipping-status-content").hide();
        });
      </script>
    {% endif %}
    <div class="klaviyo-form-container">
      <div class="klaviyo-form-SQC9KB"></div>
    </div>
    <script>
      document.addEventListener('DOMContentLoaded', function() {
        var script = document.createElement('script');
        script.async = true;
        script.type = 'text/javascript';
        script.src = 'https://static.klaviyo.com/onsite/js/klaviyo.js?company_id=Rgxhec';
        document.body.appendChild(script);
      });
    </script>

  </body>
</html>

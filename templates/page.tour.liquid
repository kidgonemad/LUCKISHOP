<style>
.tour-page-wrapper {
  position: relative;
  width: 100%;
  min-height: 100vh;
  padding: 120px 20px 40px;
  box-sizing: border-box;
  z-index: 1;
  color: white;
}

.tour-content {
  max-width: 1200px;
  margin: 0 auto;
  background: rgba(0, 0, 0, 0.3);
  padding: 40px;
  border-radius: 15px;
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
  border: 1px solid rgba(255, 192, 203, 0.1);
}

.tour-header {
  text-align: center;
  margin-bottom: 60px;
  padding-bottom: 30px;
  border-bottom: 2px solid rgba(255, 192, 203, 0.3);
}

.tour-header h1 {
  font-family: 'gog-regular', monospace;
  font-size: 4.5em;
  color: pink;
  margin-bottom: 20px;
  letter-spacing: 2px;
  text-shadow: 0 0 10px rgba(255, 192, 203, 0.5);
}

.tour-intro {
  font-size: 1.2em;
  max-width: 800px;
  margin: 0 auto;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.9);
}

.tour-list {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.tour-item {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr 1fr;
  padding: 25px;
  border-bottom: 1px solid rgba(255, 192, 203, 0.1);
  transition: all 0.3s ease;
  font-size: 1.2em;
  align-items: center;
  background: transparent;
}

.tour-item:hover {
  background: rgba(255, 192, 203, 0.05);
  transform: translateX(10px);
  border-radius: 8px;
}

.date {
  font-weight: bold;
  color: pink;
  font-size: 1.1em;
  filter: blur(1.2px);
  text-shadow: 0 0 12px rgba(255, 192, 203, 0.9);
}

.venue {
  font-style: italic;
  color: rgba(255, 255, 255, 0.9);
  filter: blur(1.2px);
  text-shadow: 0 0 12px rgba(255, 255, 255, 0.9);
}

.city {
  color: rgba(255, 255, 255, 0.7);
  filter: blur(1.2px);
  text-shadow: 0 0 12px rgba(255, 255, 255, 0.9);
}

.status {
  text-align: right;
  font-weight: bold;
  letter-spacing: 1px;
  filter: blur(1.2px);
  text-shadow: 0 0 12px rgba(255, 255, 255, 0.9);
}

.status.confirmed {
  color: #00ff95;
  text-shadow: 0 0 12px rgba(0, 255, 149, 0.9);
}

.status.crossed {
  text-decoration: line-through;
  color: #ff4444;
  opacity: 0.7;
  text-shadow: 0 0 12px rgba(255, 68, 68, 0.9);
}

.status.soon {
  color: #ffcc00;
  text-shadow: 0 0 12px rgba(255, 204, 0, 0.9);
}

.tour-item.sold-out {
  opacity: 0.7;
}

.tour-item.cancelled {
  opacity: 0.7;
}

@media (max-width: 768px) {
  .tour-header h1 {
    font-size: 2.5em;
  }

  .tour-item {
    grid-template-columns: 1fr;
    gap: 10px;
    text-align: center;
    padding: 20px 15px;
  }
  
  .status {
    text-align: center;
  }
  
  .tour-content {
    padding: 20px;
  }

  .tour-item:hover {
    transform: scale(1.02);
  }
}
</style> 
{% comment %}
  Parses product tags for per-product image control.
  Tags: img-scale:80, img-x:20, img-y:-10
  No tag = defaults (scale 100%, x 0, y 0)
{% endcomment %}
{% assign p_scale = 100 %}
{% assign p_x = 0 %}
{% assign p_y = 0 %}
{% for tag in product.tags %}
  {% if tag contains 'img-scale:' %}
    {% assign p_scale = tag | split: ':' | last | plus: 0 %}
  {% endif %}
  {% if tag contains 'img-x:' %}
    {% assign p_x = tag | split: ':' | last | plus: 0 %}
  {% endif %}
  {% if tag contains 'img-y:' %}
    {% assign p_y = tag | split: ':' | last | plus: 0 %}
  {% endif %}
{% endfor %}
--p-scale: {{ p_scale }}%; --p-x: {{ p_x }}px; --p-y: {{ p_y }}px;
   <script>
    $(document).ready(function() {
      const header = $('.top-header');
      const headerHeight = header.height();
      let lastScroll = 0;
      
      $(window).scroll(function() {
        const scrollTop = $(window).scrollTop();
        const threshold = headerHeight - 60;
        
        // Only check when scrolling down past threshold
        if (scrollTop > threshold && scrollTop > lastScroll) {
          if (!header.hasClass('sticky')) {
            header.addClass('sticky');
          }
        } 
        // Only remove sticky when scrolling up to very top
        else if (scrollTop <= 0) {
          header.removeClass('sticky');
        }
        
        lastScroll = scrollTop;
      });

      {% if cart.item_count > 0 %}
        $("#cart-quan").removeClass("disabled");
      {% endif %}
    });
  </script>

<!-- GAP TUNER — add ?tune=1 to any page URL -->
<script>
(function() {
  if (window.location.search.indexOf('tune=1') === -1) return;

  var isMobile = window.innerWidth <= 768;
  var page = '{{ template }}';
  var panel = document.createElement('div');
  panel.id = 'gap-panel';
  panel.style.cssText = 'position:fixed;bottom:10px;left:10px;background:rgba(0,0,0,0.92);color:#fff;padding:14px;z-index:99999;font-family:monospace;font-size:11px;border-radius:8px;width:300px;max-height:50vh;overflow-y:auto;cursor:move;';

  var controls = [
    {label: 'Header Margin Top', target: '.top-header', prop: 'marginTop', unit: 'px', min: -50, max: 200, step: 0.01},
    {label: 'Header Padding', target: '.header-inner', prop: 'padding', unit: 'px', min: 0, max: 100, step: 0.01},
    {label: 'Main Margin Top', target: 'main', prop: 'marginTop', unit: 'px', min: -200, max: 200, step: 0.01},
    {label: 'Main Padding Top', target: 'main', prop: 'paddingTop', unit: 'px', min: 0, max: 300, step: 0.01},
    {label: 'Announcement Bar Height', target: '.announcement-bar', prop: 'height', unit: 'px', min: 0, max: 60, step: 0.01},
    {label: 'Cart Top (up/down)', target: '#cart', prop: 'top', unit: 'px', min: -50, max: 300, step: 0.01},
    {label: 'Cart Right (left/right)', target: '#cart', prop: 'right', unit: 'px', min: -50, max: 300, step: 0.01},
    {label: 'Add to Cart Top Offset', target: '#AddToCartForm', prop: 'top', unit: 'px', min: -1000, max: 200, step: 0.01},
    {label: 'Contact Support Margin Top', target: '#support', prop: 'marginTop', unit: 'px', min: -1000, max: 200, step: 0.01},
    {label: 'Thumbnail Gap (image to previews)', target: '#thumbnails', prop: 'marginTop', unit: 'px', min: -1000, max: 100, step: 0.01},
  ];

  function getVal(c) {
    var el = document.querySelector(c.target);
    if (!el) return 0;
    return parseFloat(getComputedStyle(el)[c.prop]) || 0;
  }

  var html = '<div style="font-weight:bold;margin-bottom:8px;font-size:13px;">GAP TUNER (' + page + ') ' + (isMobile ? 'MOBILE' : 'DESKTOP') + '</div>';

  controls.forEach(function(c, i) {
    var val = getVal(c);
    html += '<div style="margin:6px 0;">' +
      '<div style="display:flex;justify-content:space-between;"><span>' + c.label + '</span><span id="gv' + i + '">' + val + '</span></div>' +
      '<input type="range" id="gr' + i + '" min="' + c.min + '" max="' + c.max + '" step="' + c.step + '" value="' + val + '" style="width:100%;accent-color:#e54d29;">' +
      '</div>';
  });

  html += '<button id="gap-copy" style="margin-top:10px;padding:8px 16px;background:#e54d29;color:#fff;border:none;cursor:pointer;font-size:12px;width:100%;">COPY VALUES</button>';
  panel.innerHTML = html;
  document.body.appendChild(panel);

  // Draggable
  var drag = false, offX, offY;
  panel.addEventListener('mousedown', function(e) {
    if (e.target.tagName === 'INPUT' || e.target.tagName === 'BUTTON') return;
    drag = true; offX = e.clientX - panel.getBoundingClientRect().left; offY = e.clientY - panel.getBoundingClientRect().top;
  });
  document.addEventListener('mousemove', function(e) { if (!drag) return; panel.style.left = (e.clientX - offX) + 'px'; panel.style.top = (e.clientY - offY) + 'px'; panel.style.bottom = 'auto'; });
  document.addEventListener('mouseup', function() { drag = false; });
  panel.addEventListener('touchstart', function(e) {
    if (e.target.tagName === 'INPUT' || e.target.tagName === 'BUTTON') return;
    drag = true; var t = e.touches[0]; offX = t.clientX - panel.getBoundingClientRect().left; offY = t.clientY - panel.getBoundingClientRect().top;
  }, {passive: true});
  document.addEventListener('touchmove', function(e) { if (!drag) return; var t = e.touches[0]; panel.style.left = (t.clientX - offX) + 'px'; panel.style.top = (t.clientY - offY) + 'px'; panel.style.bottom = 'auto'; }, {passive: true});
  document.addEventListener('touchend', function() { drag = false; });

  controls.forEach(function(c, i) {
    var slider = document.getElementById('gr' + i);
    var display = document.getElementById('gv' + i);
    slider.addEventListener('input', function() {
      var v = parseFloat(this.value);
      display.textContent = v;
      var el = document.querySelector(c.target);
      if (el) el.style[c.prop] = v + c.unit;
    });
  });

  document.getElementById('gap-copy').addEventListener('click', function() {
    var lines = [(isMobile ? '/* Mobile - ' : '/* Desktop - ') + page + ' */'];
    controls.forEach(function(c, i) {
      lines.push(c.label + ': ' + document.getElementById('gr' + i).value + c.unit);
    });
    navigator.clipboard.writeText(lines.join('\n')).then(function() {
      document.getElementById('gap-copy').textContent = 'COPIED!';
      setTimeout(function() { document.getElementById('gap-copy').textContent = 'COPY VALUES'; }, 1500);
    });
  });
})();
</script>


#contact{
	filter: invert(1) drop-shadow(0px 0px 5px rgba(0,0,0,0.5));
}

#logo{
	display:none;
}



#items{
	z-index:10;
	position:relative;
	width:calc(100% - 60px);
	max-width:1400px;
	margin:0 auto;
	overflow:hidden;
	padding-bottom:80px;
	padding-top:20px;
	display: flex;
	flex-wrap: wrap;
	justify-content: center;
	gap: var(--gap, 20px);
}

#items > * {
	font-size: 0;
}

#items a {
	display: block;
	width: calc(100% / var(--columns, 2) - var(--gap, 20px));
	box-sizing: border-box;
	position: relative;
	transition: transform 0.3s ease;
	font-size: initial;
	align-self: flex-start;
	text-decoration: none;
	color: black;
	overflow: hidden;
}

#items a img.item {
	position: relative;
	width: var(--p-scale, var(--img-scale, 100%));
	height: auto;
	display: block;
	margin: 0 auto;
	transform: translate(var(--p-x, 0px), var(--p-y, 0px));
}

#items a .item-title {
	position: absolute;
	left: var(--title-x, 50%);
	top: var(--title-y, 85%);
	transform: translate(-50%, -50%);
	font-family: 'Dot Matrix V2', monospace;
	color: black;
	font-size: var(--title-size, 14px);
	text-decoration: none;
	white-space: nowrap;
	pointer-events: none;
}

#items a .item-price {
	position: absolute;
	left: var(--price-x, 50%);
	top: var(--price-y, 92%);
	transform: translate(-50%, -50%);
	font-family: 'Dot Matrix V2', monospace;
	color: black;
	font-size: var(--price-size, 13px);
	white-space: nowrap;
	pointer-events: none;
}

#items a:hover {
	transform: scale(1.02);
}

@media only screen and (max-width: 768px) {
	#items {
		width: calc(100% - 40px);
		padding-bottom: 40px;
		padding-top: 40px;
		gap: 15px;
	}
	#items a {
		width: 100%;
	}
}

#support-link{
  color:white;
}
#support{

  text-align:center;
  width:calc(100% - 50px);
  padding:0px 25px;
  color:white;
  margin-top: 20px;
  width:auto;

}


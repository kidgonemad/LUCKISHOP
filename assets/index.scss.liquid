main {
    margin-top: -45px !important;
}

@media only screen and (max-width: 768px) {
    main {
        margin-top: -80px !important;
    }
}

body {
    margin: 0;
    padding: 0;
    min-height: 100vh;
    position: relative;
    background: none;
}

#video-bg {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    width: 100%;
    height: 100vh;
    z-index: -1;
    overflow: hidden;

    video {
        position: absolute;
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
}

#bg {
    display: none;
}

#blocker{
	position:fixed;
	z-index:1000;
	background-color:rgba(50,50,50,1);
	width:100%;height:100%;
	top:0px;left:0px;
	transition:0.2s;

	&.fade{
		opacity:0;
		pointer-events: none;
	}
}

#header{
  position:relative;
  left:0px;
  right:0px;
  margin:auto;
  top:20px;
  width:calc(100% - 140px);
  max-width:500px;
}

  #header > a > img{
    position:relative;
    left:0px;
    top:0px;
    width:100%;
  }

#container{
  z-index: 0;
  position:absolute;
  width:100%;height:100%;
  left:0px;top:0px;
	overflow:hidden;

	filter:drop-shadow(0px 2px 15px rgba(0,0,0,0.5));

	pointer-events: none;
}


.selected{
  cursor:pointer;
}



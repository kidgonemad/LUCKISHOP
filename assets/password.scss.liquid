

///////


body{
  font-family: Helvetica;
  background-color: white;
  color: black;
}

#password-content{
  position:absolute;
  width:auto;
  height:auto;
  left:50%;top:50%;
  transform: translate(-50%, -50%);
  text-align: center;
}

#password-title{
  position:relative;
  width:auto;
}

#password-main-photo{
/*   display:none; */
/*   max-height:50vw;
  max-height:50vh; */
  width:100%;
  max-width:500px;
  margin-bottom: 20px
}


#mc_embed_signup{
/*   background:red;  */
  clear:left; font:14px Helvetica,Arial,sans-serif; 
  width:100%;
}
            
            

.password-input {
  border: 0;
  border-bottom: 1px solid white;
  background-color: white;
  color: black;
  height: 25px;
  width: 110px;
  text-align: center;
  -webkit-transition-duration: 0.4s; /* Safari */
  transition-duration: 0.4s;
}

::-webkit-input-placeholder {
  font-family: Helvetica;
  text-align: center;
}

.container {
  /*         background-color: blue; */
  text-align: center;
  position: absolute; 
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  -webkit-user-select: none; /* Chrome/Safari */        
  -moz-user-select: none; /* Firefox */
  -ms-user-select: none; /* IE10+ */

}	

.container2 {
  /*         background-color: blue; */
  text-align: center;
  position: absolute; 
  top: 90%;
  right: 0;
  width: 200px;
  height: 100px;
  -webkit-user-select: none; /* Chrome/Safari */        
  -moz-user-select: none; /* Firefox */
  -ms-user-select: none; /* IE10+ */

}	

.input-button{
  position: absolute;
  visibility: hidden;
}

.password-input:focus {
  outline:none;
  width: 150px;
  border-bottom: 1px solid lightgrey;
  box-shadow: 10px;
}   


.hammer-img{
  -webkit-transition-duration: 0.4s; /* Safari */
  transition-duration: 0.4s;
  margin-bottom: 20px;
}

.hammer-img:hover{
  transform: scale(1.03); 
}

.instagram-icon {
  -webkit-transition-duration: 0.4s; /* Safari */
  transition-duration: 0.4s;
}

.instagram-icon:hover {
  transform: scale(1.2); 
}

.email-icon {
  -webkit-transition-duration: 0.4s; /* Safari */
  transition-duration: 0.4s;
}

.email-icon:hover {
  transform: scale(1.2); 
}

.twitter-icon {
  -webkit-transition-duration: 0.4s; /* Safari */
  transition-duration: 0.4s;
}

.twitter-icon:hover {
  transform: scale(1.2); 
}




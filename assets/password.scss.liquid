#status-tab {
  display: block !important;
  z-index: 9999999998;
  position: fixed !important;
  cursor: pointer;
  left: 50% !important;
  bottom: 30px !important;
  transform: translateX(-50%) !important;
  width: auto;
  height: auto;
  font-size: 12px;
  color: rgb(0,0,0);
  padding: 10px 10px;
  border-radius: 5px;
  box-shadow: 0px 0px 5px rgba(0,0,0,0.1);
  background-color: rgba(250,250,250,1);
  border: 1px solid rgba(235,235,235,1);
  padding-left: calc(10px + 12px + 10px + 0px + 0px);
  margin: 0 !important;
  right: auto !important;
  top: auto !important;
  
  img {
    position: absolute;
    top: 0;
    bottom: 0;
    margin: auto;
    left: 10px;
    height: calc(100% - 20px);
    width: auto;
    opacity: 0.75;
  }
}

#status-header{
  position:absolute;
  top:80px;
  color:black;
}

#status-exit{
  z-index:100;
  position:fixed;
  left:35px;top:35px;
  width:35px;height:35px;
  padding:5px;
  cursor:pointer;
  opacity:0.8;
}

@media only screen and (max-width: 600px) {
  #status-exit{
    left:15px;top:35px;
  }
}



#status-content {
  z-index: 900000000;
  display: none;
  position: fixed;
  width: 100%;
  height: 100%;
  top: 0;
  left: 0;
  background-color: white;
}


#status-text {
  z-index: 1;
  position: relative;
  width: 100%;
  max-width: 600px;
  margin: 0 auto;
  padding: 100px 25px;
  
  .klaviyo-form-SQC9KB {
    width: 100%;
    min-height: 300px;
    display: block;
  }
  
}